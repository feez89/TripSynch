{
  "name": "tripsync",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "dependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "overrides": {
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "scripts": {
    "postinstall": "rm -rf apps/web/node_modules/react",
    "dev:backend": "cd services/backend && npm run dev",
    "dev:mobile": "cd apps/mobile && npx expo start",
    "build:backend": "cd services/backend && npm run build",
    "test": "cd services/backend && npm test",
    "db:migrate": "cd services/backend && npm run db:migrate",
    "db:seed": "cd services/backend && npm run db:seed",
    "db:generate": "cd services/backend && npm run db:generate",
    "setup": "npm install && cd services/backend && cp .env.example .env"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}
